# Copy this file to .env and fill in your values
DATABASE_URL="postgresql://planner:plannerdev@localhost:5432/resource_planner?schema=public"

# next-auth / Keycloak (OIDC)
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=

# Local dev (docker compose keycloak):
#   AUTH_KEYCLOAK_ID=resource-planner
#   AUTH_KEYCLOAK_SECRET=dev-secret
#   AUTH_KEYCLOAK_ISSUER=http://localhost:8080/realms/resource-planner-dev

# Production (AD-backed Keycloak):
AUTH_KEYCLOAK_ID=resource-planner
AUTH_KEYCLOAK_SECRET=
AUTH_KEYCLOAK_ISSUER=https://<keycloak-host>/realms/<realm-name>
