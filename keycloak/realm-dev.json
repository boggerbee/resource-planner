{
  "realm": "resource-planner-dev",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "clients": [
    {
      "clientId": "resource-planner",
      "name": "Resource Planner (dev)",
      "enabled": true,
      "publicClient": false,
      "secret": "dev-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": ["http://localhost:3001/*"],
      "postLogoutRedirectUris": ["http://localhost:3001"],
      "webOrigins": ["http://localhost:3001"],
      "defaultClientScopes": ["web-origins", "profile", "roles", "email"],
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "user.attribute": "foo",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "roles": {
    "realm": [
      { "name": "resource-planner-admin", "description": "Full tilgang" },
      { "name": "resource-planner-rw", "description": "Allokeringer og rapporter" },
      { "name": "resource-planner-ro", "description": "Kun rapporter" }
    ]
  },
  "users": [
    {
      "username": "dev-admin",
      "email": "dev-admin@example.com",
      "firstName": "Dev",
      "lastName": "Admin",
      "enabled": true,
      "credentials": [{ "type": "password", "value": "admin123", "temporary": false }],
      "realmRoles": ["resource-planner-admin"]
    },
    {
      "username": "dev-rw",
      "email": "dev-rw@example.com",
      "firstName": "Dev",
      "lastName": "ReadWrite",
      "enabled": true,
      "credentials": [{ "type": "password", "value": "rw123", "temporary": false }],
      "realmRoles": ["resource-planner-rw"]
    },
    {
      "username": "dev-ro",
      "email": "dev-ro@example.com",
      "firstName": "Dev",
      "lastName": "ReadOnly",
      "enabled": true,
      "credentials": [{ "type": "password", "value": "ro123", "temporary": false }],
      "realmRoles": ["resource-planner-ro"]
    }
  ]
}
