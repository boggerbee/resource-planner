# Database (ekstern PostgreSQL i produksjon)
DATABASE_URL=postgresql://user:pass@db-host:5432/resource_planner

# Auth.js / NextAuth
AUTH_URL=https://<app-hostname>
AUTH_SECRET=<openssl rand -base64 32>

# Keycloak (ekstern, AD-backend, HTTPS)
AUTH_KEYCLOAK_ID=resource-planner
AUTH_KEYCLOAK_SECRET=<fra prod Keycloak>
AUTH_KEYCLOAK_ISSUER=https://<keycloak-host>/realms/<realm>

NODE_ENV=production
